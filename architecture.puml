@startuml
' Comprehensive architecture diagram for offline-doc-assistant
left to right direction
skinparam shadowing false
skinparam componentStyle rectangle

' Define external components
cloud "User (CLI)" as user

' Core application
package "offline-doc-assistant" {
  [main.py] as main
  folder "config" {
    [config.yaml] as config
  }
  component "Llama (LLM)" as llm
  component "SmartSearcher" as searcher
  component "SearchEngine" as engine
  component "Ranker" as ranker
  component "Summarizer" as summarizer
  component "DocumentChatEngine" as chatEngine
  component "FeedbackHandler" as feedback
  component "OCR Engine" as ocr
  component "File Loader" as loader
}

' Data stores
database "Vector Store / Index" as vectorStore
folder "docs/ (raw documents)" as docs
folder "models/" as models

' Interactions
user --> main : start / input
main --> config : read settings
main --> searcher : instantiate
searcher --> engine : search(query)
engine --> vectorStore : query vectors
vectorStore --> engine : retrieve docs
engine --> ranker : rank(results)
ranker --> summarizer : summarize(context)
engine --> ocr : OCR (if PDF)
searcher --> chatEngine : rephrase / summary
chatEngine --> llm : LLM inference
chatEngine --> feedback : store feedback
feedback --> vectorStore : update relevance
loader --> docs : load & chunk
loader --> vectorStore : index
main --> chatEngine : user rephrase request
main --> feedback : collect feedback

note right of main
  CLI loop handling
  options: search, list, remove, reindex
end note

@enduml

